# ── Crop Production System — Environment Variables ─────────
# Copy this file to .env and adjust for your environment.

# Environment
ENVIRONMENT=development
CORS_ORIGINS=*

# Database (TimescaleDB)
DATABASE_URL=postgresql+asyncpg://cropuser:cropsecret@localhost:5432/cropproduction

# Redis
REDIS_URL=redis://localhost:6379/0

# EMQX (MQTT)
EMQX_HOST=localhost
EMQX_PORT=1883
EMQX_ADMIN_PASSWORD=admin

# JWT (RS256)
# Leave JWT_PRIVATE_KEY and JWT_PUBLIC_KEY empty to auto-generate on first run.
# In production, inject these as secrets.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
